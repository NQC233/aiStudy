# 本文件是仓库唯一权威环境变量模板。
# 根目录 .env 是唯一实际本地运行值文件。
# 新增或重命名变量时，必须同步更新 backend/app/core/config.py 或前端 VITE_* 读取点，以及 README.md。

# 应用运行环境
# 首期本地开发建议使用 development
APP_ENV=development

# 后端服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_SIZE_MB=50
REMOTE_FILE_FETCH_TIMEOUT_SEC=15

# 前端服务配置
VITE_APP_TITLE=Paper Learning Platform
VITE_API_BASE_URL=http://localhost:8000

# 认证配置（Spec 18）
# AUTH_DEFAULT_ACCOUNT_* 用于启动时确保默认演示账户存在，并把历史 local-dev-user 资产迁移到该账户下。
AUTH_JWT_SECRET=change-me-in-env
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTH_DEV_BYPASS_ENABLED=false
AUTH_DEFAULT_ACCOUNT_ENABLED=true
AUTH_DEFAULT_ACCOUNT_ID=default-demo-user
AUTH_DEFAULT_ACCOUNT_EMAIL=demo@example.com
AUTH_DEFAULT_ACCOUNT_NAME=默认演示账户
AUTH_DEFAULT_ACCOUNT_PASSWORD=paper123456

# PostgreSQL 配置
# Spec 01 阶段为容器启动必填
POSTGRES_DB=paper_learning
POSTGRES_USER=paper_user
POSTGRES_PASSWORD=paper_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis 配置
# Spec 01 阶段为 Celery 骨架必填
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# 阿里云 OSS 配置
# Spec 03 起会正式接入
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BASE_PREFIX=uploads
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_MINERU_USE_ORIGIN_URL=true

# MinerU 配置
# Spec 04 起会正式接入
MINERU_API_KEY=
MINERU_BASE_URL=https://mineru.net/api/v4/extract/task
MINERU_MODEL_VERSION=vlm
MINERU_TIMEOUT_SEC=120
MINERU_POLL_INTERVAL_SEC=5
MINERU_POLL_TIMEOUT_SEC=600
MINERU_WEBHOOK_SECRET=

# DashScope 配置
# Spec 07 起会正式接入
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL_NAME=qwen-max
# Spec 15 重构后已拆分 Slides 专用模型配置
# 文本分析 / 视觉理解 / HTML 代码生成默认统一为 qwen3.6-plus
# 废弃变量：SLIDES_DIRECTOR_MODEL_NAME、SLIDES_IMAGE_MODEL_NAME（不要再使用）
DASHSCOPE_SLIDES_ANALYSIS_MODEL_NAME=qwen3.6-plus
DASHSCOPE_SLIDES_VISION_MODEL_NAME=qwen3.6-plus
DASHSCOPE_SLIDES_SCENE_MODEL_NAME=qwen3.6-plus
DASHSCOPE_SLIDES_HTML_MODEL_NAME=qwen3.6-plus
DASHSCOPE_SLIDES_TIMEOUT_SEC=240
DASHSCOPE_SLIDES_PLANNER_TIMEOUT_SEC=240
DASHSCOPE_SLIDES_SCENE_TIMEOUT_SEC=480
DASHSCOPE_SLIDES_HTML_TIMEOUT_SEC=480
SLIDES_SCENE_PARALLELISM=3
SLIDES_HTML_PARALLELISM=3
SLIDES_HTML_CANVAS_WIDTH=1600
SLIDES_HTML_CANVAS_HEIGHT=900
SLIDES_HTML_VALIDATION_ENABLED=true
SLIDES_HTML_VALIDATION_TIMEOUT_SEC=15
SLIDES_HTML_BATCH_TIMEOUT_SEC=600
SLIDES_HTML_BATCH_MAX_PAGES=12
SLIDES_HTML_BATCH_CHUNK_SIZE=4
SLIDES_HTML_REBUILD_TIMEOUT_SEC=180
SLIDES_HTML_FAILED_ONLY_MAX_RATIO=0.3
# Slides full rebuild 在当前 3 并行配置下通常需要 10-20 分钟；stale timeout 需覆盖长尾完成窗口。
SLIDES_PROCESSING_STALE_TIMEOUT_SEC=1800
# 文生图补位模型
DASHSCOPE_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/images/generations
DASHSCOPE_IMAGE_MODEL_NAME=qwen-image-2.0-pro
DASHSCOPE_CHAT_TIMEOUT_SEC=90
DASHSCOPE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
DASHSCOPE_EMBEDDING_MODEL_NAME=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1024
DASHSCOPE_EMBEDDING_BATCH_SIZE=8
DASHSCOPE_TTS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/audio/speech
DASHSCOPE_TTS_MODEL_NAME=cosyvoice-v3-flash
DASHSCOPE_TTS_VOICE=longxiaochun_v3
DASHSCOPE_TTS_TIMEOUT_SEC=90

# 资产知识库配置
# Spec 06 起会正式接入
KB_CHUNK_TARGET_CHARS=1200
KB_CHUNK_MAX_CHARS=1600

# Celery 配置
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_BACKOFF_SEC=5
CELERY_TASK_RETRY_BACKOFF_MAX_SEC=120
CELERY_TASK_RETRY_JITTER=true
